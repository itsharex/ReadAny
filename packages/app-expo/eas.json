{
  "cli": {
    "version": ">= 14.1.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.0",
      "preBuild": "bash scripts/cleanup-unused-modules.sh || true"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      },
      "ios": {
        "simulator": false
      },
      "node": "20.18.0",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1"
      },
      "preBuild": "bash scripts/cleanup-unused-modules.sh || true"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "node": "20.18.0",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1"
      },
      "preBuild": "bash scripts/cleanup-unused-modules.sh || true"
    }
  }
}
